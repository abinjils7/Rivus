{
  "installCommand": "npm install --prefix Backend && npm install --prefix View",
  "buildCommand": "cd View && npm run build",
  "outputDirectory": "View/dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
